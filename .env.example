# SurrealDB
SURREAL_USER=root
SURREAL_PASS=change_me
SURREAL_NS=coffeevault
SURREAL_DB=coffeevault

# Backend API
API_PORT=4000
JWT_SECRET=change_me_to_a_long_random_string

# Admin account (bootstrapped on first startup — there is no public registration)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change_me_to_a_strong_password

# Optional additional accounts, bootstrapped the same way. Format: email:password,email:password
# EXTRA_USERS=partner@example.com:change_me_too,roommate@example.com:change_me_as_well

# Frontend (exposed to the browser at build/run time)
NUXT_PUBLIC_API_BASE=/api
